{
    "layer": "top",
      "position": "bottom",
      "margin-bottom": 0,
      "modules-left": [
        "cpu",
        "cpu#freq",
        "cpu#cores",
        "custom/fanspeed",
        "temperature",
        "memory",
        "hyprland/workspaces"
        ],
      "modules-center": [
        "hyprland/window"
        ],
      "modules-right": [
        "network#speed",
        "network",
        "tray",
        "pulseaudio",
        "battery",
        "clock",
        "custom/powermenu"
      ],
      "tray": {
        "icon-size": 24,
        "spacing": 10
      },
      "hyprland/window": {
        "format": " {}",
        "rewrite": {
            "(\\d\\. )?(.*) - Chromium": "<span color=\"#4285F4\">ΎΚρ</span>  $2 ",
            "(\\d\\. )?(.*) έΑΦ Mozilla Firefox": "<span color=\"#4285F4\">≤░Ι╣</span>  $2 ",
            "vim (.*)": "<span color=\"#57A143\">Όατ</span>  $1",
            "vim": "<span color=\"#57A143\">ΎΕκ  Όατ</span> ",
            "nvim (.*)": "<span color=\"#57A143\">Όατ</span>  $1",
            "nvim": "<span color=\"#57A143\">ΎΕκ  Όατ</span> ",
            "vi (.*)": "<span color=\"#57A143\">Όατ</span>  $1",
            "vi": "<span color=\"#57A143\">ΎΕκ  Όατ</span> ",
            "alacritty (.*)": "<span color=\"#ffffff\">ΎΤΚ</span>  $1",
            "kitty (.*)": "<span color=\"#ffffff\">ΎΤΚ</span>  $1",
            "Search(.*)": "<span color=\"#a855f7\">ΌβΕ</span>  Search$1"
        },
        "separate-outputs": false
      },
      "hyprland/workspaces": {
        "format": "{icon}",
        "tooltip": "false",
        "format-icons": {
          "1": "≤░▓κ",
          "2": "≤░▓μ",
          "3": "≤░▓ξ",
          "4": "≤░▓π",
          "5": "≤░▓σ",
          "6": "≤░▓τ",
          "7": "≤░▓φ",
          "8": "≤░▓ψ",
          "9": "≤░▓▒",
          "10": "≤░┐φ",
          "active": "ΎΕΣ",
          "default": "ΎΤς"
        }
      },
      "network": {
        "format-icons": {
          "wifi": ["≤░Ψσ"],
          "ethernet": ["≤░ΙΑ"],
          "disconnected": ["≤░Ψς"]
        },
        "format-wifi": "≤░Ψσ",
        "format-ethernet": "≤░ΙΑ",
        "format-disconnected": "≤░Ψς",
        "tooltip-format": "{ifname} via {gwaddr}",
        "tooltip-format-ethernet": "{ifnanme} {ipaddr} ≤░ΙΑ",
        "tooltip-format-disconnected": "Disconnected",
        "tooltip": "true"
      },
      "network#speed": {
        "format": "≤░Θγ {bandwidthDownBits} ≤░ΧΤ {bandwidthUpBits}",
        "interval": 2,
        "tooltip": "false"
      },
      "temperature": {
        "format": "{icon} {temperatureC}┬░C",
        "critical-threshold": 85,
        "format-critical": "{temperatureC}┬░C ΎΜΘ",
        "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"],
        "interval": 2
      },
      "memory": {
        "format": "≤░Ξδ {}%",
        "tooltip": "false"
      },
      "cpu": {
        "format": "ΌΚο {usage}%",
        "tooltip": "false",
        "interval": 2
      },
      "cpu#freq": {
        "format": "{avg_frequency} GHz",
        "tooltip": "false",
        "interval": 2
      },
      "cpu#cores": {
        "format": "{icon0} {icon1} {icon2} {icon3} {icon4} {icon5} {icon6} {icon7}",
        "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
        "interval": 2
      },
      "custom/fanspeed": {
        "exec": "$HOME/.config/waybar/scripts/fan_speed.sh",
        "format": "≤░ΙΡ {} RPM",
        "interval": 5,
        "return-type": "json"
      },
      "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
          "notification": "Όχγ",
          "none": " ",
          "dnd-notification": "Όχγ",
          "dnd-none": " "
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client --close-all",
        "escape": true
      },
      "custom/powermenu": {
        "format": "ΎΑΣ",
        "tooltip": false,
        "on-click": "exec wlogout -p layer-shell"
      },
      "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}ΎΛΥ",
        "format-muted": "≤░ζθ",
        "format-icons": {
            "headphone": "≤░ΜΜ",
            "hands-free": "≤░ξ░",
            "headset": "≤░ΜΟ",
            "phone": "ΎΓΧ",
            "default": ["ΎΑπ", "ΎΑρ"]
        },
        "scroll-step": 5,
        "on-click": "pavucontrol"
      },
      "clock": {
        "format": "{:%H:%M}",
        "interval": 60,
        "tooltip": true,
        "tooltip-format": "{:%d %B %H:%M}"
      },
      "battery": {
        "states": {
          "warning": 30,
          "critical": 15
        },
        "interval": 60,
        "format": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
        "format-time": "{H}h {M}m"
      }
  }
  
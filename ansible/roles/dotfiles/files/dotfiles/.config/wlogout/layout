{
    "label" : "lock",
    "action" : "sleep 0.5; hyprlock",
    "text" : "Lock",
    "keybind" : "l"
}

{
    "label" : "hibernate",
    "action" : "sleep 0.5; systemctl hibernate",
    "text" : "Hibernate",
    "keybind" : "h"
}

{
    "label" : "logout",
    "action" : "sleep 0.5; $HOME/.config/hypr/scripts/exit.sh",
    "text" : "Exit",
    "keybind" : "e"
}

{
    "label" : "shutdown",
    "action" : "sleep 0.5; systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}

{
    "label" : "suspend",
    "action" : "sleep 0.5; systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}

{
    "label" : "reboot",
    "action" : "sleep 0.5; systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
